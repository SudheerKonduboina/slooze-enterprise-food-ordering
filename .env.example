# ============================================
# Slooze Food Ordering Platform - Environment
# ============================================

# Application
DEBUG=false
APP_NAME=Slooze Food Ordering Platform
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://slooze:slooze_secret@postgres:5432/slooze_db

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-strong-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
