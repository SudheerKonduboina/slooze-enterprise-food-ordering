{
  "info": {
    "name": "Slooze Food Ordering Platform API",
    "description": "Complete API collection for the Slooze Food Ordering Platform with RBAC and country-based access control.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Admin (Nick Fury)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"nick.fury@shield.gov\", \"password\": \"password123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var data = pm.response.json();", "pm.collectionVariables.set('token', data.access_token);"]
            }
          }]
        },
        {
          "name": "Login - Manager India (Captain Marvel)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"carol.danvers@shield.gov\", \"password\": \"password123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var data = pm.response.json();", "pm.collectionVariables.set('token', data.access_token);"]
            }
          }]
        },
        {
          "name": "Login - Manager America (Captain America)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"steve.rogers@shield.gov\", \"password\": \"password123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var data = pm.response.json();", "pm.collectionVariables.set('token', data.access_token);"]
            }
          }]
        },
        {
          "name": "Login - Member India (Thanos)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"thanos@titan.space\", \"password\": \"password123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var data = pm.response.json();", "pm.collectionVariables.set('token', data.access_token);"]
            }
          }]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "item": [
        {
          "name": "List Restaurants",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/restaurants?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["restaurants"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Restaurant by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants/rest-taj-mahal"
          }
        },
        {
          "name": "Get Restaurant Menu",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/restaurants/rest-taj-mahal/menu?page=1&page_size=50",
              "host": ["{{base_url}}"],
              "path": ["restaurants", "rest-taj-mahal", "menu"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "50" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurant_id\": \"rest-taj-mahal\",\n  \"items\": [\n    { \"menu_item_id\": \"<MENU_ITEM_ID>\", \"quantity\": 2 }\n  ],\n  \"notes\": \"Extra spicy please\"\n}"
            }
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/<ORDER_ID>"
          }
        },
        {
          "name": "Checkout Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/<ORDER_ID>/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method_id\": \"<PAYMENT_METHOD_ID>\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders/<ORDER_ID>/cancel"
          }
        },
        {
          "name": "Update Order Payment Method",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/orders/<ORDER_ID>/payment-method",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method_id\": \"<PAYMENT_METHOD_ID>\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payment Methods",
      "item": [
        {
          "name": "List Payment Methods",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/payment-methods"
          }
        },
        {
          "name": "Create Payment Method",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/payment-methods",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method_type\": \"CREDIT_CARD\",\n  \"label\": \"My Visa Card\",\n  \"details\": \"**** **** **** 4242\",\n  \"is_default\": true\n}"
            }
          }
        },
        {
          "name": "Delete Payment Method",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/payment-methods/<METHOD_ID>"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Get Role Permissions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/permissions"
          }
        }
      ]
    }
  ]
}
